# Copy this file to .env and fill in values before running locally.

# The key the DPW platform uses to call your app.
# Set to any value for local development.
# In production, set to the value you provide when registering your app.
DPW_API_KEY=change-me

# HTTP port (default: 8000)
PORT=8000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
